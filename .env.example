# PostgreSQL (Docker Compose spawns this)
POSTGRES_USER=tecnolicity
POSTGRES_PASSWORD=tecnolicity
POSTGRES_DB=tecnolicity

# Drizzle connection string
DATABASE_URL=postgresql://tecnolicity:tecnolicity@localhost:5432/tecnolicity

# Embedding dimension (OpenAI ada-002 = 1536). Env-overridable to avoid provider lock-in.
EMBEDDING_DIM=1536

# Server
PORT=3000
NODE_ENV=development

# Document fetching (Playwright worker, Phase 5)
STORAGE_ROOT=./storage
DOCFETCH_ENABLED=false
DOCFETCH_CONCURRENCY=1
DOCFETCH_DELAY_MS=2000

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:5173
