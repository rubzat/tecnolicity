# Copy to .env.production on the server and fill in real values.
# Used by: docker compose --env-file .env.production -f docker-compose.prod.yml up -d

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=tecnolicity
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=tecnolicity

# --- Frontend / CORS -----------------------------------------------------
# Public URL the site will be served from. The frontend calls the API
# same-origin through nginx's /api proxy, so this only matters for direct
# API access from other origins.
CORS_ORIGIN=https://your-domain.example
# Host port nginx binds to. Put a reverse proxy (Caddy/Traefik/nginx) with
# TLS in front of this in production; keep 80 here and terminate TLS there.
HTTP_PORT=80

# --- Document fetching (Playwright worker) --------------------------------
DOCS_FETCH_ENABLED=true
DOCS_FETCH_CONCURRENCY=1
DOCS_FETCH_DELAY_MS=2000
DOCS_FETCH_TIMEOUT_MS=30000
DOCS_FETCH_HEADLESS_FALLBACK=true

# --- Vigente scraper (daily cron) -----------------------------------------
SCRAPER_MAX_PAGES=50
SCRAPER_DELAY_MS=2000
SCRAPER_TIMEOUT_MS=45000
SCRAPER_PAGE_SIZE=100
SCRAPE_CRON_ENABLED=true
SCRAPE_CRON_SCHEDULE=0 6 * * *
VIGENTE_DETAIL_CACHE_TTL_MS=86400000

# --- Misc ------------------------------------------------------------------
EMBEDDING_DIM=1536

# --- Admin auth + public API rate limiting (PR11) --------------------------
# Gates /api/admin/* only — the public read API stays open, just rate
# limited (see PUBLIC_RATE_LIMIT_PER_MINUTE below).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Long random string — signs the admin session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_TTL_MS=604800000
# Baseline for callers with no API key (per IP, per minute).
PUBLIC_RATE_LIMIT_PER_MINUTE=30
# Default limit for a newly-issued API key (per minute); overridable per key.
API_KEY_DEFAULT_RATE_LIMIT_PER_MINUTE=300
